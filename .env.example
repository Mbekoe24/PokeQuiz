# PokéAPI is public and does not require a key. These vars are optional:
# - Override base URL (e.g. your own reverse proxy).
# - Add a bearer token only if your proxy or another API requires it.

# VITE_POKEAPI_BASE_URL=https://pokeapi.co/api/v2
# VITE_POKEAPI_API_KEY=

# Any variable exposed to the browser must be prefixed with VITE_.
# Never put true secrets in VITE_* vars—they are embedded in the client bundle.
# For private keys, use a small backend that calls the API server-side.
